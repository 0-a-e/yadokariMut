# =============================================================================
# YadokariMut 環境変数テンプレート
# 使い方: cp .env.example .env  のあと、必要なキーだけ埋める
# =============================================================================

# --- LLM (DeepSeek) ----------------------------------------------------------
# 画面内 AI アシスタント・キャンペーン/設備の LLM 分類で使用
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# --- Geocoding (optional) ----------------------------------------------------
# provider に Google を指定したときのみ必須。未設定なら他プロバイダ経路を利用
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Data layer (現行は multi-source v2) --------------------------------------
# v2 | v1
# 未設定時: YADOKARIMUT_V2_DB_PATH がある、または ./yadokari_mut_v2.db が存在すれば v2
YADOKARIMUT_DATA_LAYER=v2
# YADOKARIMUT_DB_PATH=./yadokari_mut.db
# YADOKARIMUT_V2_DB_PATH=./yadokari_mut_v2.db

# --- Agent / chat checkpoint (optional) --------------------------------------
# YADOKARIMUT_CHECKPOINT_DB=./data/agent_checkpoints.db

# --- Scheduler (Docker Compose では environment でも指定) ---------------------
# ENABLE_SCHEDULER=true
# SCHEDULER_CRON=0 2 * * *

# --- Scrape HTTP / proxy (default off = 直接取得のみ) ------------------------
# off | fallback | always_proxy
SCRAPE_HTTP_MODE=off
# SCRAPE_HTTP_PROXY=http://user:pass@host:port
SCRAPE_HTTP_MAX_RETRIES=2
SCRAPE_HTTP_TIMEOUT_SECONDS=45
SCRAPE_PROXY_COOLDOWN_SECONDS=600
